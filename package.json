{
  "name": "claude-ai",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "web:dev": "pnpm --filter web dev",
    "web:build": "pnpm --filter web build",
    "web:preview": "pnpm --filter web preview",
    "web:lint": "pnpm --filter web lint",

    "api:start": "pnpm --filter api start",
    "api:dev": "pnpm --filter api start:dev",
    "api:build": "pnpm --filter api build",
    "api:test": "pnpm --filter api test",
    "api:lint": "pnpm --filter api lint",

    "dev": "pnpm --parallel --filter '*' run dev",
    "build": "pnpm --filter '*' run build",
    "lint": "pnpm --filter '*' run lint",
    "test": "pnpm --filter '*' run test"
  }
}
